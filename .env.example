# Copy this file to `.env` and fill in the keys you want to use.
# At least ONE provider must be configured (or run with METAPHOR_MOCK=1).

# --- Anthropic ---
# Get a key at: console.anthropic.com
ANTHROPIC_API_KEY=

# --- OpenAI ---
# Get a key at: platform.openai.com
OPENAI_API_KEY=

# --- Google Gemini ---
# Get a free key at: aistudio.google.com
# LiteLLM model strings: gemini/gemini-1.5-pro, gemini/gemini-1.5-flash, gemini/gemini-2.0-flash
GEMINI_API_KEY=

# --- OpenRouter (access to 100+ models with one key) ---
# Get a key at: openrouter.ai
# LiteLLM model strings: openrouter/anthropic/claude-3.5-sonnet,
#   openrouter/google/gemini-pro-1.5, openrouter/mistralai/mixtral-8x7b-instruct, ...
OPENROUTER_API_KEY=

# --- Defaults (used unless overridden in the UI) ---
# Any LiteLLM model string works. Examples:
#   anthropic/claude-sonnet-4-6  |  openai/gpt-4o
#   gemini/gemini-1.5-pro        |  openrouter/anthropic/claude-3.5-sonnet
METAPHOR_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
METAPHOR_DEFAULT_TEMPERATURE=0.7

# --- Dev / testing ---
# Set to 1 to skip all LLM calls and use canned mock responses.
# METAPHOR_MOCK=1

# --- Storage ---
METAPHOR_DATA_DIR=./data/runs

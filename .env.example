# Copy this file to `.env` and fill in the keys you want to use.
# At least ONE provider must be configured.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Defaults (used unless overridden in the UI) ---
# Any LiteLLM model string works: "anthropic/claude-sonnet-4-6", "openai/gpt-4o", ...
METAPHOR_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
METAPHOR_DEFAULT_TEMPERATURE=0.7

# --- Storage ---
# Where conversation transcripts + extracted facts get persisted.
METAPHOR_DATA_DIR=./data/runs
